# Copy to a secure path and set FABIO_ENV_FILE to that path.
# Do not commit real credentials.

MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111
MOOMOO_TRADE_ENV=SIMULATE

# Paper: map large Moomoo total_assets to a $10k-style book (SIMULATE on by default).
# FABIO_MODELED_EQUITY_ENABLED=1
# FABIO_MOOMOO_REFERENCE_EQUITY=1000000
# FABIO_DISPLAY_EQUITY_START=10000

POLYGON_API_KEY=replace_me
FABIO_DATA_SOURCE=polygon

# Historical options comparison backtests reuse POLYGON_API_KEY against Polygon Options
# (contracts + /v3/quotes). Requires a Polygon plan that includes Options history.
# Smoke-test: python3 tools/verify_polygon_options_access.py

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_PERSONAL_CHAT_ID=replace_me
TELEGRAM_GROUP_CHAT_ID=replace_me

GOOGLE_SHEET_ID=replace_me
# Prefer a path outside this repo tree.
GOOGLE_CREDS_PATH=/secure/path/google_credentials.json

# Runtime guard
FABIO_RUNTIME_MAX_RESTARTS=5
FABIO_RUNTIME_BACKOFF_BASE_SEC=15
FABIO_RUNTIME_BACKOFF_CAP_SEC=300
FABIO_OPTIONS_ONLY_EXECUTION=1
# Auto-adopt Moomoo open option positions at startup into strategy state.
# 1 (default): adopt each orphan that passes code/qty/cost checks; if ANY open
#   positions exist and NONE can be adopted, the bot PAUSES entries until fixed.
# 0: never auto-adopt; if ANY open broker positions exist at startup, the bot PAUSES
#   until manual clear (flat account or turn adoption back on after validation).
# See README "Startup paused: reconcile triage" for PauseReason codes and recovery.
FABIO_AUTO_ADOPT_OPEN_POSITIONS=1

# Optional stop confirmation secret for Telegram control
TELEGRAM_STOP_CONFIRM_CODE=replace_me
